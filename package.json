{
  "displayName": "PurpleAir",
  "name": "homebridge-purpleair",
  "version": "1.0.9",
  "description": "A Homebridge plugin to connect PurpleAir sensors.",
  "license": "Apache-2.0",
  "keywords": [
    "homebridge-plugin"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tillkruss/homebridge-purpleair.git"
  },
