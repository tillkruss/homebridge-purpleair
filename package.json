    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "homebridge": "^2.0.1",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "axios": "^1.4.0"
  }
